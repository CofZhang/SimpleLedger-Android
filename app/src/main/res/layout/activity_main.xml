<?xml version="1.0" encoding="utf-8"?>
<!-- 4.6 修复：正确处理凸起按钮位置，圆心位于 Tab 栏上边缘线 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_warm_spots">

    <!-- Fragment 容器：由各 Fragment 自行处理状态栏 insets -->
    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 底部毛玻璃导航栏（整体避开系统底部安全区域） -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- 底部 Tab 栏 -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_bottom_nav"
            app:elevation="0dp"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />
    </LinearLayout>

    <!-- 4.6 凸起圆形玻璃主按钮（记账）：
         独立浮在所有视图之上，由 MainActivity 通过 insets 动态设置 marginBottom，
         使按钮圆心位于 Tab 栏上边缘线上，整个圆形完整可见 -->
    <ImageButton
        android:id="@+id/fabAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_fab_add"
        android:elevation="8dp"
        android:src="@android:drawable/ic_input_add"
        android:scaleType="centerInside"
        android:tint="@android:color/white" />

</FrameLayout>
