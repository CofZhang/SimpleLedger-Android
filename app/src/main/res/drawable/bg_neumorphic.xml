<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_bg" />
            <corners android:radius="16dp" />
            <padding android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_dark" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:left="0dp" android:top="2dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/neu_bg" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
