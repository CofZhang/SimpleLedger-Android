<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleLedger">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".CalendarActivity" />
        <activity android:name=".AddRecordActivity" />
        <activity android:name=".StatsActivity" />
        <activity android:name=".CategoryManageActivity" />
        <activity android:name=".BudgetActivity" />
        <activity android:name=".ProjectsActivity" />
        <activity android:name=".ProjectDetailActivity" />
        <activity android:name=".AccountsActivity" />
    </application>

</manifest>
